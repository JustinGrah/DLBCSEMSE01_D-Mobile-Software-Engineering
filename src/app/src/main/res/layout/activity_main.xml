<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootFrame"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_main" />

    <View
        android:id="@+id/vOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88FFFFFF"/>

<!--
    Hauptlayout der App.
    Zeigt Titel, nächsten Gastgeber und geplante Spieltermine.
    Termin-Cards sind sichtbar, damit Navigation und Buttons getestet werden können.
-->

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <!-- Button oben links: Neues Spiel -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNewGame"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/new_game_button"
        android:textColor="@android:color/white"
        android:textAllCaps="true"
        android:elevation="4dp"
        app:backgroundTint="#C62828"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Button oben rechts: Einstellungen -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettings"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/settings_button"
        android:elevation="4dp"
        app:backgroundTint="#C62828"
        app:cornerRadius="28dp"
        app:icon="@drawable/ic_settings"
        app:iconTint="@android:color/white"
        app:iconSize="28dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollbarer Inhalt -->
    <ScrollView
        android:id="@+id/scrollMain"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/btnNewGame"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/mainContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Titel -->
            <TextView
                android:id="@+id/tvMainTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/main_title"
                android:textColor="@android:color/black"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <!-- Info zum nächsten Gastgeber: derweil nur als Text -->
            <TextView
                android:id="@+id/tvNextHost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/next_host_subtitle"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:layout_marginBottom="24dp"/>

            <!-- Bereich: Geplante Termine + Chat -->
            <LinearLayout
                android:id="@+id/plannedDatesHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- Titel + Termin hinzufügen -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvPlannedDatesTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/planned_dates_title"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>

                    <!-- Plus Button zum Hinzufügen eines Termins -->
                    <TextView
                        android:id="@+id/btnAddDate"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="@string/add_symbol"
                        android:textColor="@android:color/black"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- Chat Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChat"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/chat_button"
                    android:textColor="@android:color/white"
                    android:textAllCaps="true"
                    android:elevation="4dp"
                    app:backgroundTint="#C62828"/>
            </LinearLayout>

            <!-- Hier kommen die Sessions hin -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="32dp"
                android:clipToPadding="false"/>
        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
