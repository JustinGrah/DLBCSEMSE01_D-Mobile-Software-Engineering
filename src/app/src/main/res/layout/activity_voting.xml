<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".VotingActivity">

    <!-- Zurück-Pfeil oben links -->
    <!-- Zurück-Pfeil oben links -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="@dimen/screen_margin"
        android:layout_marginTop="@dimen/screen_margin"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:padding="@dimen/spacing_small"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/black" />

    <!-- Titel mittig -->
    <TextView
        android:id="@+id/tvVotingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/title_top_margin"
        android:text="@string/voting_title"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollbarer Hauptinhalt -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollVoting"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/content_top_margin"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvVotingTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_margin"
            android:paddingTop="@dimen/spacing_medium"
            android:paddingEnd="@dimen/screen_margin"
            android:paddingBottom="@dimen/spacing_large">

            <!-- SPIELE: Die Angezeigte Spiele werden später aus dem
            Spiele-Poll, wo sich die registrierte Spiele befinden, geladen
            -->
            <TextView
                android:id="@+id/tvGamesSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voting_games_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGamesHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/subtitle_spacing"
                android:text="@string/voting_games_hint"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/text_hint_gray" />

            <!-- Spieleliste -->
            <LinearLayout
                android:id="@+id/layoutGamesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:orientation="vertical">

                <!-- Spiel 1 -->
                <LinearLayout
                    android:id="@+id/itemGame1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/voting_item_spacing"
                    android:orientation="vertical">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbGame1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#C62828"
                        android:text="@string/demo_game_1" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/result_bar_height"
                        android:layout_marginTop="@dimen/progress_top_margin">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressGame1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:progress="40"
                            android:max="100"
                            app:indicatorColor="#C62828"
                            app:trackColor="@color/voting_bar_background"
                            app:trackCornerRadius="@dimen/result_bar_corner_radius" />

                        <TextView
                            android:id="@+id/tvProgressGame1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/demo_progress_40"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Spiel 2 -->
                <LinearLayout
                    android:id="@+id/itemGame2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/voting_item_spacing"
                    android:orientation="vertical">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbGame2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#C62828"
                        android:text="@string/demo_game_2" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/result_bar_height"
                        android:layout_marginTop="@dimen/progress_top_margin">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressGame2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:progress="65"
                            android:max="100"
                            app:indicatorColor="#C62828"
                            app:trackColor="@color/voting_bar_background"
                            app:trackCornerRadius="@dimen/result_bar_corner_radius" />

                        <TextView
                            android:id="@+id/tvProgressGame2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/demo_progress_65"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Spiel 3 -->
                <LinearLayout
                    android:id="@+id/itemGame3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/voting_item_spacing"
                    android:orientation="vertical">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbGame3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#C62828"
                        android:text="@string/demo_game_3" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/result_bar_height"
                        android:layout_marginTop="@dimen/progress_top_margin">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressGame3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:progress="25"
                            android:max="100"
                            app:indicatorColor="#C62828"
                            app:trackColor="@color/voting_bar_background"
                            app:trackCornerRadius="@dimen/result_bar_corner_radius" />

                        <TextView
                            android:id="@+id/tvProgressGame3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/demo_progress_25"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Spiel 4 -->
                <LinearLayout
                    android:id="@+id/itemGame4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbGame4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#C62828"
                        android:text="@string/demo_game_4" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/result_bar_height"
                        android:layout_marginTop="@dimen/progress_top_margin">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressGame4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:progress="80"
                            android:max="100"
                            app:indicatorColor="#C62828"
                            app:trackColor="@color/voting_bar_background"
                            app:trackCornerRadius="@dimen/result_bar_corner_radius" />

                        <TextView
                            android:id="@+id/tvProgressGame4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/demo_progress_80"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Material Divider zwischen Spiele und Essen -->
            <com.google.android.material.divider.MaterialDivider
                android:id="@+id/dividerVotingSections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_divider_margin_top"
                android:layout_marginBottom="@dimen/section_divider_margin_bottom"
                app:dividerColor="@color/voting_divider"
                app:dividerThickness="@dimen/divider_thickness" />

            <!-- ESSEN -->
            <TextView
                android:id="@+id/tvFoodSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voting_food_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFoodHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xsmall"
                android:text="@string/voting_food_hint"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/text_hint_gray" />

            <!-- Essensliste -->
            <LinearLayout
                android:id="@+id/layoutFoodContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:orientation="vertical">

                <!-- Essen 1 -->
                <LinearLayout
                    android:id="@+id/itemFood1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/voting_item_spacing"
                    android:orientation="vertical">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbFoodPizza"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#C62828"
                        android:text="@string/food_pizza" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/result_bar_height"
                        android:layout_marginTop="@dimen/progress_top_margin">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressFoodPizza"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:progress="70"
                            android:max="100"
                            app:indicatorColor="#C62828"
                            app:trackColor="@color/voting_bar_background"
                            app:trackCornerRadius="@dimen/result_bar_corner_radius" />

                        <TextView
                            android:id="@+id/tvProgressFoodPizza"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/demo_progress_70"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Essen 2 -->
                <LinearLayout
                    android:id="@+id/itemFood2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/voting_item_spacing"
                    android:orientation="vertical">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbFoodBurger"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#C62828"
                        android:text="@string/food_burger" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/result_bar_height"
                        android:layout_marginTop="@dimen/progress_top_margin">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressFoodBurger"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:progress="45"
                            android:max="100"
                            app:indicatorColor="#C62828"
                            app:trackColor="@color/voting_bar_background"
                            app:trackCornerRadius="@dimen/result_bar_corner_radius" />

                        <TextView
                            android:id="@+id/tvProgressFoodBurger"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/demo_progress_45"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Essen 3 -->
                <LinearLayout
                    android:id="@+id/itemFood3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/voting_item_spacing"
                    android:orientation="vertical">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbFoodAsian"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#C62828"
                        android:text="@string/food_asian" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/result_bar_height"
                        android:layout_marginTop="@dimen/progress_top_margin">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressFoodAsian"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:progress="55"
                            android:max="100"
                            app:indicatorColor="#C62828"
                            app:trackColor="@color/voting_bar_background"
                            app:trackCornerRadius="@dimen/result_bar_corner_radius" />

                        <TextView
                            android:id="@+id/tvProgressFoodAsian"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/demo_progress_55"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Essen 4 -->
                <LinearLayout
                    android:id="@+id/itemFood4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbFoodItalian"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#C62828"
                        android:text="@string/food_italian" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/result_bar_height"
                        android:layout_marginTop="@dimen/progress_top_margin">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressFoodItalian"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:progress="30"
                            android:max="100"
                            app:indicatorColor="#C62828"
                            app:trackColor="@color/voting_bar_background"
                            app:trackCornerRadius="@dimen/result_bar_corner_radius" />

                        <TextView
                            android:id="@+id/tvProgressFoodItalian"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/demo_progress_30"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>