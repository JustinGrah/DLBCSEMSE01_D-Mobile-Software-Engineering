    <!-- Hintergrundbild -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_main"
        android:contentDescription="@null" />

    <!-- Weißer Overlay -->
    <View
        android:id="@+id/vOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88FFFFFF" />

    <!-- Titel -->
    <TextView
        android:id="@+id/tvVotingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voting"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hauptkarte -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/votingCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tvVotingTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Spiele Voting Titel -->
                <TextView
                    android:id="@+id/tvGameVotingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spiel-Voting"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Spiele RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvGameVoting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="16dp" />

                <!-- Essen Voting Titel -->
                <TextView
                    android:id="@+id/tvFoodVotingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Essens-Voting"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <!-- Essen RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFoodVoting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="16dp" />

                <!-- Abstimmen Button -->
                <Button
                    android:id="@+id/btnSubmitVotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Abstimmen"
                    android:textAllCaps="false"
                    android:layout_marginTop="20dp"
                    android:textColor="@android:color/white"
                    android:padding="12dp" />

            </LinearLayout>
        </ScrollView>

    </com.google.android.material.card.MaterialCardView>


    </androidx.constraintlayout.widget.ConstraintLayout>