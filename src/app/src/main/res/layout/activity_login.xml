<?xml version="1.0" encoding="utf-8"?>

<!--
     Layout der Login-Seite.
     Diese Oberfläche enthält die Eingabefelder für Benutzername und Passwort
     sowie die Buttons für Login und Registrierung.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dice">

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CCFFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--
         Überschrift der Seite (Login / Registrierung).
    -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="@string/login_header"
        android:textColor="@android:color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
         Container für alle Login-Elemente.
         Hier befinden sich Beschreibung, Eingabefelder und Buttons.
    -->
    <LinearLayout
        android:id="@+id/loginContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeader">

        <!--
             Kurze Erklärung für den Benutzer,
             dass hier die Login-Daten eingegeben werden sollen.
        -->
        <TextView
            android:id="@+id/tvLoginTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="@string/login_subtitle"
            android:textColor="#404040"
            android:textSize="18sp" />

        <!--
             Eingabefeld für den Benutzernamen.
        -->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUsername"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:hintEnabled="false"
            app:boxStrokeColor="#404040">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/username"
                android:textColorHint="#505050"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!--
             Eingabefeld für das Passwort.
             Der Inhalt wird durch inputType="textPassword" verborgen dargestellt.
        -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:hintEnabled="false"
            app:boxStrokeColor="#404040">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/password"
                android:textColorHint="#505050"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <!--
             Link für "Passwort vergessen".
             Aktuell ohne Funktion.
        -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="48dp"
            android:padding="8dp"
            android:text="@string/forgot_password"
            android:textColor="#C62828"
            android:textSize="16sp" />

        <!--
             Button zum Einloggen.
             Die eigentliche Login-Logik wird später implementiert.
        -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/login_button"
            android:backgroundTint="#C62828"/>

        <!--
             Button zum Wechsel auf die Registrierungsseite.
             Beim Klick wird die RegisterActivity geöffnet.
        -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/register_button"
            android:backgroundTint="#C62828"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>