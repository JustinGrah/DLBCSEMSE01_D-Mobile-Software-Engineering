<?xml version="1.0" encoding="utf-8"?>


<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="24dp">


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBewertung"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="498dp"
            android:padding="24dp">

            <!--
                Titel des Bewertungsdialogs.
                Zeigt dem Nutzer an, dass eine Bewertung abgegeben werden kann.
            -->

            <TextView
                android:id="@+id/tvBewertungSubtitle4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="252dp"
                android:gravity="center"
                android:text="@string/bewertung_subtitle"
                android:textColor="#666666"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBewertungTitle" />

            <RatingBar
                android:id="@+id/ratingBarOverall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="232dp"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1.0"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.493"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBewertungSubtitle" />

            <TextView
                android:id="@+id/tvBewertungSubtitle3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="144dp"
                android:gravity="center"
                android:text="Wie hat das Essen Geschmeckt"
                android:textColor="#666666"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBewertungTitle" />

            <RatingBar
                android:id="@+id/ratingBarFood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="124dp"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1.0"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.493"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBewertungSubtitle" />

            <TextView
                android:id="@+id/tvBewertungTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/bewertung_title"
                android:textColor="@android:color/black"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!--
                Untertitel mit kurzer Erklärung für den Nutzer.
                Beschreibt, dass der vergangene Abend bewertet werden soll.
            -->

            <!--
                RatingBar zur Bewertung des Abends.
                Der Nutzer kann hier 1 bis 5 Sterne auswählen.
            -->
            <TextView
                android:id="@+id/tvBewertungSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="Wie war der Gastgeber?"
                android:textColor="#666666"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBewertungTitle" />

            <!--
                Button zum Absenden der Bewertung.
                Nach dem Klick wird die gewählte Sternebewertung gespeichert
                bzw. an die entsprechende Logik der App übergeben.
            -->
            <RatingBar
                android:id="@+id/ratingBarHost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1.0"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.493"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBewertungSubtitle" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogBack"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="28dp"
                android:elevation="4dp"
                android:text="Zurück"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:backgroundTint="#C62828"
                app:cornerRadius="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ratingBarHost"
                app:layout_constraintVertical_bias="1.0" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>