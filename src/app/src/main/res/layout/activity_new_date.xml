<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- =========================
             ZURÜCK PFEIL (links oben)
             ========================= -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="centerInside"
            android:contentDescription="back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- =========================
             TITEL (zentriert)
             ========================= -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/new_termin_title"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- =========================
             GASTGEBER
             ========================= -->
        <TextView
            android:id="@+id/tv_host_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/host_label"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Spinner
            android:id="@+id/sp_host"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            app:layout_constraintTop_toBottomOf="@id/tv_host_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- =========================
             DATUM & UHRZEIT
             ========================= -->
        <TextView
            android:id="@+id/tv_date_time_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/datetime_label"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/sp_host"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/et_date_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="@string/datetime_hint"
            android:inputType="none"
            app:layout_constraintTop_toBottomOf="@id/tv_date_time_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- =========================
             ORT
             ========================= -->
        <TextView
            android:id="@+id/tv_location_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/location_label"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/et_date_time"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/et_location_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="@string/location_hint"
            android:inputType="text"
            app:layout_constraintTop_toBottomOf="@id/tv_location_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- =========================
             SPEICHERN BUTTON
             ========================= -->
        <Button
            android:id="@+id/btn_save_termin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/save_button"
            android:layout_marginTop="18dp"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/et_location_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>